NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# Required for /consulta/agendar photo uploads through Vercel Blob.
# Get it from Vercel Storage > Blob > .env.local, or run `vercel env pull`.
BLOB_READ_WRITE_TOKEN=""

# Required for persisting completed /consulta/agendar intakes.
# Pull these from Vercel/Neon, for example with `vercel env pull`.
POSTGRES_URL=""
POSTGRES_PRISMA_URL=""
POSTGRES_URL_NON_POOLING=""

# Payment provider adapter. Current implementation supports "stripe" and "hotmart".
PAYMENT_PROVIDER="stripe"
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
STRIPE_API_VERSION="2025-05-28.basil"
STRIPE_CONSULTATION_PRICE_CENTS="35000"

# Optional legacy Hotmart adapter.
HOTMART_CHECKOUT_URL=""
# Optional: require Hotmart webhook calls to include this value as
# ?token=, x-hotmart-hottok, x-hotmart-token, or x-webhook-token.
HOTMART_WEBHOOK_TOKEN=""

# Scheduling provider adapter. Current implementation supports "cal".
SCHEDULING_PROVIDER="cal"
CAL_API_KEY=""
CAL_API_VERSION="2024-08-13"
CAL_EVENT_TYPE_ID=""
CAL_USERNAME=""
CAL_EVENT_TYPE_SLUG=""
CAL_TIMEZONE="America/Sao_Paulo"
CAL_WEBHOOK_SECRET=""
